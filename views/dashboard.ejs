<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - Dating Sites Extension</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif;
            background: #0f0f1a;
            color: #e0e0e0;
            padding: 20px;
        }
        .container {
            max-width: 1400px;
            margin: 0 auto;
        }
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 0;
            border-bottom: 1px solid #2a2a3e;
            margin-bottom: 25px;
        }
        .header h1 {
            font-size: 24px;
            color: #fff;
        }
        .header .user-info {
            display: flex;
            align-items: center;
            gap: 15px;
        }
        .header .user-info span {
            color: #888;
        }
        .header .user-info a {
            color: #ff6b6b;
            text-decoration: none;
            padding: 6px 14px;
            border: 1px solid #ff6b6b;
            border-radius: 6px;
            transition: all 0.2s;
        }
        .header .user-info a:hover {
            background: #ff6b6b;
            color: #fff;
        }
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 15px;
            margin-bottom: 25px;
        }
        .stat-card {
            background: #1a1a2e;
            padding: 15px 20px;
            border-radius: 10px;
            border: 1px solid #2a2a3e;
            text-align: center;
        }
        .stat-card .number {
            font-size: 28px;
            font-weight: bold;
            color: #4CAF50;
        }
        .stat-card .label {
            font-size: 12px;
            color: #888;
            margin-top: 4px;
        }
        .stat-card .number.pending { color: #FF9800; }
        .stat-card .number.revoked { color: #f44336; }
        .stat-card .number.active { color: #4CAF50; }
        
        .section {
            background: #1a1a2e;
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 25px;
            border: 1px solid #2a2a3e;
        }
        .section h2 {
            font-size: 18px;
            margin-bottom: 15px;
            color: #fff;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .section h2 .badge {
            font-size: 12px;
            padding: 2px 10px;
            border-radius: 12px;
            background: #2a2a3e;
            color: #888;
        }
        .form-group {
            margin-bottom: 12px;
        }
        .form-group label {
            display: block;
            font-size: 13px;
            color: #aaa;
            margin-bottom: 4px;
        }
        .form-group input, .form-group select {
            width: 100%;
            padding: 10px 14px;
            background: #0f0f1a;
            border: 1px solid #2a2a3e;
            border-radius: 6px;
            color: #e0e0e0;
            font-size: 14px;
        }
        .form-group input:focus, .form-group select:focus {
            outline: none;
            border-color: #4CAF50;
        }
        .form-row {
            display: flex;
            gap: 15px;
            align-items: flex-end;
        }
        .form-row .form-group {
            flex: 1;
        }
        .btn {
            padding: 10px 24px;
            border: none;
            border-radius: 6px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
        }
        .btn-primary {
            background: #4CAF50;
            color: #fff;
        }
        .btn-primary:hover {
            background: #45a049;
        }
        .btn-danger {
            background: #f44336;
            color: #fff;
        }
        .btn-danger:hover {
            background: #d32f2f;
        }
        .btn-warning {
            background: #FF9800;
            color: #fff;
        }
        .btn-warning:hover {
            background: #e68900;
        }
        .btn-sm {
            padding: 4px 12px;
            font-size: 12px;
        }
        .table-container {
            overflow-x: auto;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
        }
        table th {
            text-align: left;
            padding: 10px 12px;
            background: #0f0f1a;
            color: #888;
            font-weight: 600;
            border-bottom: 1px solid #2a2a3e;
        }
        table td {
            padding: 10px 12px;
            border-bottom: 1px solid #1a1a2e;
        }
        table tr:hover td {
            background: #1a1a2e;
        }
        .status-badge {
            padding: 3px 10px;
            border-radius: 12px;
            font-size: 11px;
            font-weight: 600;
        }
        .status-badge.approved { background: rgba(76, 175, 80, 0.2); color: #4CAF50; }
        .status-badge.pending { background: rgba(255, 152, 0, 0.2); color: #FF9800; }
        .status-badge.revoked { background: rgba(244, 67, 54, 0.2); color: #f44336; }
        .status-badge.active { background: rgba(76, 175, 80, 0.2); color: #4CAF50; }
        .status-badge.inactive { background: rgba(244, 67, 54, 0.2); color: #f44336; }
        .status-badge.not_found { background: rgba(244, 67, 54, 0.2); color: #f44336; }
        
        .code-text {
            font-family: monospace;
            font-weight: bold;
            color: #4CAF50;
            font-size: 14px;
            letter-spacing: 1px;
        }
        .text-muted { color: #666; }
        .text-success { color: #4CAF50; }
        .text-danger { color: #f44336; }
        .mt-2 { margin-top: 10px; }
        .mb-2 { margin-bottom: 10px; }
        .alert {
            padding: 10px 14px;
            border-radius: 6px;
            margin-top: 10px;
            font-size: 13px;
        }
        .alert-success {
            background: rgba(76, 175, 80, 0.15);
            border: 1px solid #4CAF50;
            color: #4CAF50;
        }
        .alert-danger {
            background: rgba(244, 67, 54, 0.15);
            border: 1px solid #f44336;
            color: #f44336;
        }
        .alert-info {
            background: rgba(33, 150, 243, 0.15);
            border: 1px solid #2196F3;
            color: #2196F3;
        }
        .flex { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
        .gap-2 { gap: 8px; }
        .hidden { display: none !important; }
        
        /* Tabs */
        .tabs {
            display: flex;
            gap: 4px;
            margin-bottom: 15px;
            background: #0f0f1a;
            padding: 4px;
            border-radius: 8px;
        }
        .tab-btn {
            padding: 8px 16px;
            border: none;
            background: transparent;
            color: #888;
            border-radius: 6px;
            cursor: pointer;
            font-size: 13px;
            transition: all 0.2s;
        }
        .tab-btn.active {
            background: #2a2a3e;
            color: #fff;
        }
        .tab-btn:hover {
            color: #fff;
        }
        .tab-content {
            display: none;
        }
        .tab-content.active {
            display: block;
        }
        
        .empty-state {
            text-align: center;
            padding: 30px;
            color: #666;
        }
        .empty-state .icon {
            font-size: 48px;
            margin-bottom: 10px;
        }
        
        @media (max-width: 768px) {
            .form-row {
                flex-direction: column;
            }
            .header {
                flex-direction: column;
                gap: 10px;
                text-align: center;
            }
            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Header -->
        <div class="header">
            <h1>🚀 Dating Sites Extension Admin</h1>
            <div class="user-info">
                <span>👤 <%= username %></span>
                <a href="/logout">Logout</a>
            </div>
        </div>

        <!-- Stats -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="number"><%= stats.total || 0 %></div>
                <div class="label">Total Devices</div>
            </div>
            <div class="stat-card">
                <div class="number active"><%= stats.approved || 0 %></div>
                <div class="label">Active</div>
            </div>
            <div class="stat-card">
                <div class="number pending"><%= stats.pending || 0 %></div>
                <div class="label">Pending</div>
            </div>
            <div class="stat-card">
                <div class="number revoked"><%= stats.revoked || 0 %></div>
                <div class="label">Revoked</div>
            </div>
            <div class="stat-card">
                <div class="number"><%= stats.activeCodes || 0 %></div>
                <div class="label">Active Codes</div>
            </div>
            <div class="stat-card">
                <div class="number pending"><%= stats.pendingRequests || 0 %></div>
                <div class="label">Pending Requests</div>
            </div>
        </div>

        <!-- Tabs -->
        <div class="tabs">
            <button class="tab-btn active" data-tab="codes">🔑 Codes</button>
            <button class="tab-btn" data-tab="devices">📱 Devices</button>
            <button class="tab-btn" data-tab="requests">📨 Requests</button>
            <button class="tab-btn" data-tab="coderequests">📨 Code Requests</button>
            <button class="tab-btn" data-tab="generate">➕ Generate Code</button>
        </div>

        <!-- ============================================ -->
        <!-- TAB: CODES -->
        <!-- ============================================ -->
        <div class="tab-content active" id="tab-codes">
            <div class="section">
                <h2>🔑 Active Codes <span class="badge"><%= codes ? codes.length : 0 %></span></h2>
                <div class="table-container">
                    <table>
                        <thead>
                            <tr>
                                <th>Code</th>
                                <th>Used / Max</th>
                                <th>Status</th>
                                <th>Created By</th>
                                <th>Created At</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (codes && codes.length > 0) { %>
                                <% codes.forEach(function(code) { %>
                                    <tr>
                                        <td><span class="code-text"><%= code.code %></span></td>
                                        <td><%= code.used_count || 0 %> / <%= code.max_devices || 10 %></td>
                                        <td><span class="status-badge active">Active</span></td>
                                        <td><%= code.created_by || 'admin' %></td>
                                        <td><%= new Date(code.created_at).toLocaleDateString() %></td>
                                        <td>
                                            <button class="btn btn-danger btn-sm" onclick="deactivateCode('<%= code.code %>')">Deactivate</button>
                                            <button class="btn btn-warning btn-sm" onclick="extendCode('<%= code.code %>')">Extend</button>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr><td colspan="6" class="empty-state">No active codes found</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- ============================================ -->
        <!-- TAB: DEVICES -->
        <!-- ============================================ -->
        <div class="tab-content" id="tab-devices">
            <div class="section">
                <h2>📱 Devices <span class="badge"><%= devices ? devices.length : 0 %></span></h2>
                <div class="table-container">
                    <table>
                        <thead>
                            <tr>
                                <th>Device ID</th>
                                <th>Code</th>
                                <th>Status</th>
                                <th>Approved At</th>
                                <th>Pings</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (devices && devices.length > 0) { %>
                                <% devices.forEach(function(device) { %>
                                    <tr>
                                        <td><%= device.device_id %></td>
                                        <td><span class="code-text"><%= device.code || 'N/A' %></span></td>
                                        <td><span class="status-badge <%= device.status %>"><%= device.status %></span></td>
                                        <td><%= device.approved_at ? new Date(device.approved_at).toLocaleDateString() : '-' %></td>
                                        <td><%= device.ping_count || 0 %></td>
                                        <td>
                                            <% if (device.status === 'revoked') { %>
                                                <button class="btn btn-primary btn-sm" onclick="reactivateDevice('<%= device.device_id %>')">Reactivate</button>
                                            <% } %>
                                            <button class="btn btn-danger btn-sm" onclick="removeDevice('<%= device.device_id %>')">Remove</button>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr><td colspan="6" class="empty-state">No devices found</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- ============================================ -->
        <!-- TAB: REQUESTS (More Slots) -->
        <!-- ============================================ -->
        <div class="tab-content" id="tab-requests">
            <div class="section">
                <h2>📨 More Slots Requests <span class="badge"><%= requests ? requests.length : 0 %></span></h2>
                <div class="table-container">
                    <table>
                        <thead>
                            <tr>
                                <th>Device ID</th>
                                <th>Code</th>
                                <th>Reason</th>
                                <th>Requested At</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (requests && requests.length > 0) { %>
                                <% requests.forEach(function(req) { %>
                                    <tr>
                                        <td><%= req.device_id %></td>
                                        <td><span class="code-text"><%= req.code || 'N/A' %></span></td>
                                        <td><%= req.reason || 'Need more slots' %></td>
                                        <td><%= new Date(req.requested_at).toLocaleDateString() %></td>
                                        <td>
                                            <button class="btn btn-success btn-sm" onclick="approveRequest('<%= req.id %>')">Approve</button>
                                            <button class="btn btn-danger btn-sm" onclick="rejectRequest('<%= req.id %>')">Reject</button>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr><td colspan="5" class="empty-state">No pending requests</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- ============================================ -->
        <!-- TAB: CODE REQUESTS -->
        <!-- ============================================ -->
        <div class="tab-content" id="tab-coderequests">
            <div class="section">
                <h2>📨 Code Requests <span class="badge"><%= codeRequests ? codeRequests.length : 0 %></span></h2>
                <div class="table-container">
                    <table>
                        <thead>
                            <tr>
                                <th>Device ID</th>
                                <th>Reason</th>
                                <th>Requested At</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (codeRequests && codeRequests.length > 0) { %>
                                <% codeRequests.forEach(function(req) { %>
                                    <tr>
                                        <td><%= req.device_id %></td>
                                        <td><%= req.reason || 'Requesting code' %></td>
                                        <td><%= new Date(req.requested_at).toLocaleDateString() %></td>
                                        <td>
                                            <button class="btn btn-success btn-sm" onclick="generateCodeForUser('<%= req.device_id %>')">Generate Code</button>
                                            <button class="btn btn-danger btn-sm" onclick="rejectCodeRequest('<%= req.id %>')">Reject</button>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr><td colspan="4" class="empty-state">No pending code requests</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- ============================================ -->
        <!-- TAB: GENERATE CODE - ONLY USERNAME -->
        <!-- ============================================ -->
        <div class="tab-content" id="tab-generate">
            <div class="section">
                <h2>➕ Generate Code</h2>
                <p class="text-muted mb-2">Enter a username to generate a new activation code. The code will have a limit of 10 devices.</p>
                
                <form id="generateCodeForm">
                    <div class="form-row">
                        <div class="form-group">
                            <label>Username (Device ID)</label>
                            <input type="text" id="genUsername" class="form-control" placeholder="Enter username" required>
                        </div>
                        <div class="form-group">
                            <button type="submit" class="btn btn-primary" style="width:100%;">Generate Code</button>
                        </div>
                    </div>
                </form>
                
                <div id="generateResult" class="mt-2"></div>
            </div>
        </div>

    </div>

    <script>
        // ============================================
        // TABS
        // ============================================
        document.querySelectorAll('.tab-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
                document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
                document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
                this.classList.add('active');
                document.getElementById('tab-' + this.dataset.tab).classList.add('active');
            });
        });

        // ============================================
        // GENERATE CODE - ONLY USERNAME
        // ============================================
        document.getElementById('generateCodeForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            const username = document.getElementById('genUsername').value.trim();
            
            if (!username) {
                alert('Please enter a username');
                return;
            }
            
            const resultDiv = document.getElementById('generateResult');
            resultDiv.innerHTML = '<div class="alert alert-info">⏳ Generating code...</div>';
            
            try {
                const response = await fetch('/api/generate-code', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ username: username })
                });
                
                const data = await response.json();
                
                if (data.success) {
                    resultDiv.innerHTML = `
                        <div class="alert alert-success">
                            ✅ Code generated: <strong>${data.code}</strong><br>
                            Username: ${data.username}<br>
                            Max devices: 10<br>
                            Request removed from list.
                        </div>
                    `;
                    document.getElementById('genUsername').value = '';
                    // Refresh after 2 seconds
                    setTimeout(() => location.reload(), 2000);
                } else {
                    resultDiv.innerHTML = `<div class="alert alert-danger">❌ ${data.error || 'Failed to generate code'}</div>`;
                }
            } catch (error) {
                resultDiv.innerHTML = `<div class="alert alert-danger">❌ Error: ${error.message}</div>`;
            }
        });

        // ============================================
        // DEACTIVATE CODE
        // ============================================
        async function deactivateCode(code) {
            if (!confirm(`Deactivate code ${code}?\n\nAll devices using this code will be revoked.`)) return;
            
            try {
                const response = await fetch(`/api/code/${code}/deactivate`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                const data = await response.json();
                
                if (data.success) {
                    alert(`✅ Code ${code} deactivated! ${data.devicesRevoked || 0} devices revoked.`);
                    location.reload();
                } else {
                    alert(`❌ Failed: ${data.error}`);
                }
            } catch (error) {
                alert(`❌ Error: ${error.message}`);
            }
        }

        // ============================================
        // EXTEND CODE
        // ============================================
        async function extendCode(code) {
            const maxDevices = prompt(`Enter new max devices for code ${code}:`, '10');
            if (!maxDevices) return;
            if (isNaN(maxDevices) || parseInt(maxDevices) < 1) {
                alert('Please enter a valid number');
                return;
            }
            
            try {
                const response = await fetch(`/api/code/${code}/extend`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ maxDevices: parseInt(maxDevices) })
                });
                const data = await response.json();
                
                if (data.success) {
                    alert(`✅ Code ${code} extended to ${maxDevices} devices`);
                    location.reload();
                } else {
                    alert(`❌ Failed: ${data.error}`);
                }
            } catch (error) {
                alert(`❌ Error: ${error.message}`);
            }
        }

        // ============================================
        // REMOVE DEVICE
        // ============================================
        async function removeDevice(deviceId) {
            if (!confirm(`Remove device ${deviceId}?\n\nThis will free up a slot on the code.`)) return;
            
            try {
                const response = await fetch(`/api/device/${deviceId}`, {
                    method: 'DELETE'
                });
                const data = await response.json();
                
                if (data.success) {
                    alert(`✅ Device removed! Slot freed.`);
                    location.reload();
                } else {
                    alert(`❌ Failed: ${data.error}`);
                }
            } catch (error) {
                alert(`❌ Error: ${error.message}`);
            }
        }

        // ============================================
        // REACTIVATE DEVICE
        // ============================================
        async function reactivateDevice(deviceId) {
            if (!confirm(`Reactivate device ${deviceId}?`)) return;
            
            try {
                const response = await fetch(`/api/reactivate/${deviceId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                const data = await response.json();
                
                if (data.success) {
                    alert(`✅ Device reactivated!`);
                    location.reload();
                } else {
                    alert(`❌ Failed: ${data.error}`);
                }
            } catch (error) {
                alert(`❌ Error: ${error.message}`);
            }
        }

        // ============================================
        // APPROVE REQUEST (More Slots)
        // ============================================
        async function approveRequest(requestId) {
            if (!confirm('Approve this request?')) return;
            
            try {
                const response = await fetch(`/api/request/${requestId}/respond`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ status: 'approved', response: 'Approved by admin' })
                });
                const data = await response.json();
                
                if (data.success) {
                    alert(`✅ Request approved!`);
                    location.reload();
                } else {
                    alert(`❌ Failed: ${data.error}`);
                }
            } catch (error) {
                alert(`❌ Error: ${error.message}`);
            }
        }

        // ============================================
        // REJECT REQUEST (More Slots)
        // ============================================
        async function rejectRequest(requestId) {
            if (!confirm('Reject this request?')) return;
            
            try {
                const response = await fetch(`/api/request/${requestId}/respond`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ status: 'rejected', response: 'Rejected by admin' })
                });
                const data = await response.json();
                
                if (data.success) {
                    alert(`✅ Request rejected`);
                    location.reload();
                } else {
                    alert(`❌ Failed: ${data.error}`);
                }
            } catch (error) {
                alert(`❌ Error: ${error.message}`);
            }
        }

        // ============================================
        // GENERATE CODE FOR USER (from Code Requests tab)
        // ============================================
        async function generateCodeForUser(username) {
            if (!username) {
                alert('Invalid username');
                return;
            }
            
            if (!confirm(`Generate code for ${username}?`)) return;
            
            try {
                const response = await fetch('/api/generate-code', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ username: username })
                });
                
                const data = await response.json();
                
                if (data.success) {
                    alert(`✅ Code generated: ${data.code}\nUsername: ${data.username}\nRequest removed from list.`);
                    location.reload();
                } else {
                    alert(`❌ Failed: ${data.error}`);
                }
            } catch (error) {
                alert(`❌ Error: ${error.message}`);
            }
        }

        // ============================================
        // REJECT CODE REQUEST
        // ============================================
        async function rejectCodeRequest(requestId) {
            if (!confirm('Reject this code request?')) return;
            
            try {
                const response = await fetch(`/api/request/${requestId}/respond`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ status: 'rejected', response: 'Rejected by admin' })
                });
                const data = await response.json();
                
                if (data.success) {
                    alert(`✅ Request rejected`);
                    location.reload();
                } else {
                    alert(`❌ Failed: ${data.error}`);
                }
            } catch (error) {
                alert(`❌ Error: ${error.message}`);
            }
        }

        // ============================================
        // AUTO REFRESH (every 30 seconds)
        // ============================================
        // setInterval(() => {
        //     if (!document.hidden) {
        //         location.reload();
        //     }
        // }, 30000);
    </script>
</body>
