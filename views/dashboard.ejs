<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard - Wantmatures Approval</title>
  <style>
    *{margin:0;padding:0;box-sizing:border-box}
    body{font-family:'Segoe UI',Arial,sans-serif;background:#0d1117;color:#c9d1d9;padding:20px}
    .container{max-width:1400px;margin:0 auto}
    .header{display:flex;justify-content:space-between;align-items:center;padding:15px 20px;background:#161b22;border-radius:10px;border:1px solid #30363d;margin-bottom:20px}
    .header h1{font-size:22px;color:#f0f6fc}
    .header .user{color:#8b949e;font-size:14px}
    .header .user span{color:#f0f6fc}
    .logout-btn{background:#da3633;color:#fff;border:none;padding:8px 16px;border-radius:6px;cursor:pointer;font-size:13px}
    .logout-btn:hover{background:#f85149}
    .stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:12px;margin-bottom:20px}
    .stat-card{background:#161b22;border:1px solid #30363d;border-radius:8px;padding:15px;text-align:center}
    .stat-card .number{font-size:28px;font-weight:bold;color:#f0f6fc}
    .stat-card .label{font-size:12px;color:#8b949e;margin-top:4px}
    .stat-card .number.green{color:#3fb950}
    .stat-card .number.orange{color:#d29922}
    .stat-card .number.red{color:#f85149}
    .stat-card .number.blue{color:#58a6ff}
    .stat-card .number.purple{color:#bc8cff}
    .section{background:#161b22;border:1px solid #30363d;border-radius:10px;padding:20px;margin-bottom:20px}
    .section h2{font-size:16px;color:#f0f6fc;margin-bottom:15px}
    .section h2 .badge{background:#1f6feb;color:#fff;font-size:11px;padding:2px 10px;border-radius:12px;margin-left:8px}
    .section h2 .badge.orange{background:#d29922}
    .section h2 .badge.red{background:#da3633}
    .code-gen{background:#0d1117;padding:15px;border-radius:8px;border:1px solid #30363d;margin-bottom:15px}
    .code-gen h3{color:#f0f6fc;font-size:14px;margin-bottom:10px}
    .code-gen .gen-row{display:flex;gap:10px;align-items:flex-end;flex-wrap:wrap}
    .code-gen .gen-field{flex:1;min-width:150px}
    .code-gen .gen-field label{color:#8b949e;font-size:12px;display:block;margin-bottom:4px}
    .code-gen .gen-field input{width:100%;padding:8px 12px;background:#0d1117;border:1px solid #30363d;border-radius:6px;color:#f0f6fc;font-size:13px}
    .code-gen .gen-field input:focus{outline:none;border-color:#58a6ff}
    .code-gen .gen-btn{padding:8px 24px;background:#238636;color:#fff;border:none;border-radius:6px;cursor:pointer;font-weight:bold;font-size:13px}
    .code-gen .gen-btn:hover{background:#2ea043}
    .code-gen .gen-btn:disabled{opacity:0.5;cursor:not-allowed}
    .code-gen .gen-result{margin-top:10px;font-size:13px;font-family:monospace;padding:8px 12px;background:rgba(255,255,255,0.03);border-radius:4px;min-height:30px}
    table{width:100%;border-collapse:collapse;font-size:13px}
    th{text-align:left;padding:10px 12px;border-bottom:2px solid #30363d;color:#8b949e;font-weight:600}
    td{padding:10px 12px;border-bottom:1px solid #21262d;vertical-align:middle}
    tr:hover{background:#1c2128}
    .status-badge{display:inline-block;padding:2px 12px;border-radius:12px;font-size:11px;font-weight:600}
    .status-badge.approved{background:#23863633;color:#3fb950}
    .status-badge.pending{background:#d2992233;color:#d29922}
    .status-badge.revoked{background:#da363333;color:#f85149}
    .status-badge.not_found{background:#8b949e33;color:#8b949e}
    .btn-sm{background:#21262d;border:1px solid #30363d;color:#c9d1d9;padding:4px 12px;border-radius:4px;cursor:pointer;font-size:12px;margin:2px}
    .btn-sm:hover{background:#30363d}
    .btn-sm.approve{background:#238636;border-color:#238636;color:#fff}
    .btn-sm.approve:hover{background:#2ea043}
    .btn-sm.revoke{background:#da3633;border-color:#da3633;color:#fff}
    .btn-sm.revoke:hover{background:#f85149}
    .btn-sm.remove{background:#8b949e;border-color:#8b949e;color:#fff}
    .btn-sm.remove:hover{background:#6e7681}
    .btn-sm.reactivate{background:#1f6feb;border-color:#1f6feb;color:#fff}
    .btn-sm.reactivate:hover{background:#388bfd}
    .btn-sm.extend{background:#1f6feb;border-color:#1f6feb;color:#fff}
    .btn-sm.extend:hover{background:#388bfd}
    .btn-sm.edit{background:#d29922;border-color:#d29922;color:#fff}
    .btn-sm.edit:hover{background:#e6a700}
    .empty{color:#8b949e;text-align:center;padding:20px}
    .request-item{background:#0d1117;border:1px solid #30363d;border-radius:6px;padding:12px 16px;margin-bottom:8px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap}
    .request-item .info{flex:1}
    .request-item .info .device{font-weight:bold;color:#f0f6fc}
    .request-item .info .code{color:#58a6ff;font-family:monospace}
    .request-item .info .reason{color:#8b949e;font-size:12px;margin-top:2px}
    .request-item .info .time{font-size:10px;color:#8b949e;margin-top:2px}
    .request-item .actions{display:flex;gap:6px}
    .tabs{display:flex;gap:4px;margin-bottom:15px;border-bottom:1px solid #30363d;flex-wrap:wrap}
    .tab{padding:8px 16px;cursor:pointer;color:#8b949e;border-bottom:2px solid transparent;font-size:13px}
    .tab.active{color:#f0f6fc;border-bottom-color:#58a6ff}
    .tab:hover{color:#f0f6fc}
    .tab-content{display:none}
    .tab-content.active{display:block}
    .limit-full{color:#d29922;font-size:11px;font-weight:bold}
    .auto-approve-badge{background:#23863633;color:#3fb950;padding:2px 10px;border-radius:12px;font-size:10px;display:inline-block}
    @media(max-width:768px){.header{flex-wrap:wrap;gap:10px}.code-gen .gen-row{flex-direction:column;align-items:stretch}.code-gen .gen-field{min-width:auto}table{font-size:11px}td,th{padding:6px 8px}}
  </style>
</head>
<body>
<div class="container">
  <div class="header">
    <h1>🔐 Approval Dashboard <span class="auto-approve-badge">⚡ AUTO-APPROVE</span></h1>
    <div>
      <span class="user">👤 <span><%= username %></span></span>
      <form action="/logout" method="GET" style="display:inline">
        <button type="submit" class="logout-btn">Logout</button>
      </form>
    </div>
  </div>

  <!-- Stats -->
  <div class="stats">
    <div class="stat-card"><div class="number"><%= stats.total %></div><div class="label">Total Devices</div></div>
    <div class="stat-card"><div class="number orange"><%= stats.pending %></div><div class="label">Pending</div></div>
    <div class="stat-card"><div class="number green"><%= stats.approved %></div><div class="label">Auto-Approved</div></div>
    <div class="stat-card"><div class="number red"><%= stats.revoked %></div><div class="label">Revoked</div></div>
    <div class="stat-card"><div class="number blue"><%= stats.totalCodes %></div><div class="label">Codes</div></div>
    <div class="stat-card"><div class="number purple"><%= stats.pendingRequests %></div><div class="label">Pending Requests</div></div>
  </div>

  <!-- Tabs -->
  <div class="tabs">
    <div class="tab active" data-tab="devices">📱 Devices</div>
    <div class="tab" data-tab="codes">🔑 Codes <% if (stats.totalCodes > 0) { %><span class="badge"><%= stats.totalCodes %></span><% } %></div>
    <div class="tab" data-tab="requests">📨 Device Requests <% if (stats.pendingRequests > 0) { %><span class="badge orange"><%= stats.pendingRequests %></span><% } %></div>
    <div class="tab" data-tab="coderequests">📨 Code Requests <% if (codeRequests && codeRequests.length > 0) { %><span class="badge orange"><%= codeRequests.length %></span><% } %></div>
  </div>

  <!-- ==================== TAB: DEVICES ==================== -->
  <div id="tab-devices" class="tab-content active">
    <div class="section">
      <h2>📱 Devices <span class="badge"><%= devices.length %></span></h2>
      <p style="color:#8b949e;font-size:12px;margin-bottom:10px">⚡ Devices are auto-approved when they enter a valid code.</p>
      <% if (devices.length === 0) { %>
        <div class="empty">No devices registered yet.</div>
      <% } else { %>
        <div style="overflow-x:auto">
          <table>
            <thead>
              <tr>
                <th>Device ID</th>
                <th>Code</th>
                <th>Status</th>
                <th>Pings</th>
                <th>Created</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% devices.forEach(device => { %>
                <tr>
                  <td style="font-family:monospace;font-size:11px"><%= device.device_id ? device.device_id.substring(0,20) + '…' : 'Unknown' %></td>
                  <td style="font-family:monospace;color:#58a6ff"><%= device.code || '—' %></td>
                  <td><span class="status-badge <%= device.status %>"><%= device.status %></span></td>
                  <td><%= device.ping_count || 0 %></td>
                  <td style="font-size:11px"><%= new Date(device.created_at).toLocaleDateString() %></td>
                  <td>
                    <button class="btn-sm remove" onclick="removeUser('<%= device.device_id %>')">🗑️ Remove</button>
                    <button class="btn-sm edit" onclick="editDevice('<%= device.device_id %>')">✏️ Edit</button>
                    <% if (device.status === 'revoked') { %>
                      <button class="btn-sm reactivate" onclick="reactivateDevice('<%= device.device_id %>')">Reactivate</button>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>

  <!-- ==================== TAB: CODES ==================== -->
  <div id="tab-codes" class="tab-content">
    <div class="section">
      <h2>🔑 Activation Codes <span class="badge"><%= codes.length %></span></h2>
      <p style="color:#8b949e;font-size:12px;margin-bottom:10px">⚡ Users enter these codes and are auto-approved instantly.</p>
      
      <!-- SIMPLIFIED CODE GENERATION -->
      <div class="code-gen">
        <h3>🚀 Generate New Code</h3>
        <div class="gen-row">
          <div class="gen-field">
            <label>👤 Username</label>
            <input type="text" id="gen-username" placeholder="Enter username" autocomplete="off">
          </div>
          <div class="gen-field" style="min-width:120px;flex:0.5;">
            <label>📊 Max Devices</label>
            <input type="number" id="gen-max-devices" value="10" min="1" max="100">
          </div>
          <button class="gen-btn" id="gen-btn" onclick="generateCodeSimple()">🚀 Generate</button>
        </div>
        <div class="gen-result" id="gen-result">Enter a username and click Generate</div>
      </div>

      <% if (codes.length === 0) { %>
        <div class="empty">No codes generated yet.</div>
      <% } else { %>
        <div style="overflow-x:auto">
          <table>
            <thead>
              <tr>
                <th>Code</th>
                <th>Used / Max</th>
                <th>Status</th>
                <th>Created</th>
                <th>Notes</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% codes.forEach(code => { 
                const usage = code.used_count || 0;
                const max = code.max_devices || 10;
                const isFull = usage >= max;
              %>
                <tr>
                  <td style="font-family:monospace;font-size:16px;color:#58a6ff;letter-spacing:1px"><%= code.code %></td>
                  <td><%= usage %> / <%= max %> <% if (isFull) { %> <span class="limit-full">🔴 FULL</span><% } %></td>
                  <td><span class="status-badge <%= code.is_active ? 'approved' : 'revoked' %>"><%= code.is_active ? 'Active' : 'Inactive' %></span></td>
                  <td style="font-size:11px"><%= new Date(code.created_at).toLocaleDateString() %></td>
                  <td style="font-size:11px;color:#8b949e"><%= code.notes || '—' %></td>
                  <td>
                    <% if (code.is_active) { %>
                      <button class="btn-sm revoke" onclick="deactivateCode('<%= code.code %>')">Deactivate</button>
                      <button class="btn-sm extend" onclick="extendCode('<%= code.code %>')">Extend</button>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>

  <!-- ==================== TAB: DEVICE REQUESTS ==================== -->
  <div id="tab-requests" class="tab-content">
    <div class="section">
      <h2>📨 Device Requests <span class="badge orange"><%= stats.pendingRequests %></span></h2>
      <p style="color:#8b949e;font-size:12px;margin-bottom:10px">
        Users request device access. You can approve to add them or reject.
      </p>
      <% 
        const pendingRequests = requests || [];
        const hasPending = pendingRequests.length > 0;
      %>
      <% if (!hasPending) { %>
        <div class="empty">No pending device requests.</div>
      <% } else { %>
        <% pendingRequests.forEach(req => { %>
          <div class="request-item">
            <div class="info">
              <div class="device">📱 <span style="font-family:monospace;font-size:12px"><%= req.device_id ? req.device_id.substring(0,20) + '…' : 'Unknown' %></span></div>
              <div class="code">🔑 Code: <span style="font-family:monospace"><%= req.code || 'No code' %></span></div>
              <div class="reason">💬 <%= req.reason || 'Requesting device access' %></div>
              <div class="time">📅 Requested: <%= new Date(req.requested_at).toLocaleString() %></div>
            </div>
            <div class="actions">
              <button class="btn-sm approve" onclick="approveDeviceRequest('<%= req.id %>', '<%= req.device_id %>')">✅ Approve</button>
              <button class="btn-sm revoke" onclick="rejectRequest('<%= req.id %>')">❌ Reject</button>
            </div>
          </div>
        <% }) %>
      <% } %>
    </div>
  </div>

  <!-- ==================== TAB: CODE REQUESTS ==================== -->
  <div id="tab-coderequests" class="tab-content">
    <div class="section">
      <h2>📨 Code Requests <span class="badge orange"><%= codeRequests ? codeRequests.length : 0 %></span></h2>
      <p style="color:#8b949e;font-size:12px;margin-bottom:10px">Users requesting activation codes. Generate a code for them.</p>
      
      <% if (!codeRequests || codeRequests.length === 0) { %>
        <div class="empty">No code requests.</div>
      <% } else { %>
        <% codeRequests.forEach(req => { %>
          <div class="request-item">
            <div class="info">
              <div class="device">📱 <span style="font-family:monospace;font-size:12px"><%= req.device_id ? req.device_id.substring(0,20) + '…' : 'Unknown' %></span></div>
              <div class="reason">💬 <%= req.reason || 'No reason provided' %></div>
              <div class="time">📅 Requested: <%= new Date(req.requested_at).toLocaleString() %></div>
            </div>
            <div class="actions">
              <button class="btn-sm approve" onclick="generateCodeForUser('<%= req.id %>', '<%= req.device_id %>')">🎯 Generate Code</button>
              <button class="btn-sm revoke" onclick="rejectRequest('<%= req.id %>')">Reject</button>
            </div>
          </div>
        <% }) %>
      <% } %>
    </div>
  </div>

  <div style="text-align:center;color:#8b949e;font-size:12px;margin-top:20px;border-top:1px solid #21262d;padding-top:15px">
    Wantmatures Auto Clicker v5.9.0 • Auto-Approval System • ⚡ Instant Activation
  </div>
</div>

<script>
// ============================================
// TAB SWITCHING
// ============================================
document.querySelectorAll('.tab').forEach(tab => {
  tab.addEventListener('click', function() {
    document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
    this.classList.add('active');
    document.getElementById('tab-' + this.dataset.tab).classList.add('active');
  });
});

// ============================================
// API REQUEST HELPER
// ============================================
async function apiRequest(url, method = 'GET', data = null) {
  const options = { 
    method, 
    headers: { 'Content-Type': 'application/json' } 
  };
  if (data) options.body = JSON.stringify(data);
  const res = await fetch(url, options);
  return res.json();
}

function showToast(message, type = 'info') {
  alert(message);
}

// ============================================
// SIMPLIFIED: GENERATE CODE (Just username + device limit)
// ============================================
async function generateCodeSimple() {
  const username = document.getElementById('gen-username').value.trim();
  const maxDevices = parseInt(document.getElementById('gen-max-devices').value) || 10;
  const resultDiv = document.getElementById('gen-result');
  const genBtn = document.getElementById('gen-btn');
  
  if (!username) {
    resultDiv.innerHTML = '⚠️ Please enter a username';
    resultDiv.style.color = '#f85149';
    return;
  }
  
  if (maxDevices < 1) {
    resultDiv.innerHTML = '⚠️ Max devices must be at least 1';
    resultDiv.style.color = '#f85149';
    return;
  }
  
  resultDiv.innerHTML = '⏳ Generating code...';
  resultDiv.style.color = '#d29922';
  genBtn.disabled = true;
  genBtn.textContent = '⏳...';
  
  try {
    const result = await apiRequest('/api/generate-code', 'POST', { 
      username: username,
      maxDevices: maxDevices
    });
    
    if (result.success) {
      resultDiv.innerHTML = '✅ Code: <strong style="font-size:18px;color:#58a6ff;">' + result.code + '</strong> for <strong>' + result.username + '</strong> (max ' + result.maxDevices + ' devices)';
      resultDiv.style.color = '#3fb950';
      showToast('✅ Code generated: ' + result.code + ' for ' + username, 'success');
      document.getElementById('gen-username').value = '';
      setTimeout(() => location.reload(), 2000);
    } else {
      resultDiv.innerHTML = '❌ ' + (result.error || 'Failed to generate code');
      resultDiv.style.color = '#f85149';
      showToast('❌ Failed: ' + (result.error || 'Unknown error'), 'error');
    }
  } catch (e) {
    resultDiv.innerHTML = '❌ Error: ' + e.message;
    resultDiv.style.color = '#f85149';
    showToast('❌ Error: ' + e.message, 'error');
  }
  
  genBtn.disabled = false;
  genBtn.textContent = '🚀 Generate';
}

// Enter key support for generate
document.getElementById('gen-username').addEventListener('keypress', function(e) {
  if (e.key === 'Enter') generateCodeSimple();
});
document.getElementById('gen-max-devices').addEventListener('keypress', function(e) {
  if (e.key === 'Enter') generateCodeSimple();
});

// ============================================
// DEACTIVATE CODE
// ============================================
async function deactivateCode(code) {
  if (!confirm('Deactivate code ' + code + '? Users with this code will lose access.')) return;
  try {
    const result = await apiRequest('/api/code/' + code + '/deactivate', 'POST');
    if (result.success) {
      showToast('✅ Code deactivated', 'success');
      location.reload();
    } else {
      showToast('❌ Failed: ' + (result.error || 'Unknown error'), 'error');
    }
  } catch (e) {
    showToast('❌ Error: ' + e.message, 'error');
  }
}

// ============================================
// EXTEND CODE
// ============================================
async function extendCode(code) {
  const newMax = prompt('Enter new max devices for code ' + code + ':', '20');
  if (newMax === null) return;
  const maxDevices = parseInt(newMax);
  if (isNaN(maxDevices) || maxDevices < 1) {
    showToast('Invalid number', 'error');
    return;
  }
  try {
    const result = await apiRequest('/api/code/' + code + '/extend', 'POST', { maxDevices });
    if (result.success) {
      showToast('✅ Code extended to ' + maxDevices + ' devices', 'success');
      location.reload();
    } else {
      showToast('❌ Failed: ' + (result.error || 'Unknown error'), 'error');
    }
  } catch (e) {
    showToast('❌ Error: ' + e.message, 'error');
  }
}

// ============================================
// REMOVE USER
// ============================================
async function removeUser(deviceId) {
  if (!confirm('🗑️ Remove this user? This will FREE UP a slot and the device will need to re-enter the code.')) return;
  try {
    const result = await apiRequest('/api/device/' + deviceId, 'DELETE');
    if (result.success) {
      showToast('✅ User removed! Slot freed.', 'success');
      location.reload();
    } else {
      showToast('❌ Failed: ' + (result.error || 'Unknown error'), 'error');
    }
  } catch (e) {
    showToast('❌ Error: ' + e.message, 'error');
  }
}

// ============================================
// REACTIVATE DEVICE
// ============================================
async function reactivateDevice(deviceId) {
  if (!confirm('Reactivate this device?')) return;
  try {
    const result = await apiRequest('/api/reactivate/' + deviceId, 'POST');
    if (result.success) {
      showToast('✅ Device reactivated', 'success');
      location.reload();
    } else {
      showToast('❌ Failed: ' + (result.error || 'Unknown error'), 'error');
    }
  } catch (e) {
    showToast('❌ Error: ' + e.message, 'error');
  }
}

// ============================================
// EDIT DEVICE - Admin can manually add/edit devices
// ============================================
async function editDevice(deviceId) {
  const action = prompt('What would you like to do?\n\n1. Assign device to a code\n2. Remove device\n3. Reactivate device\n\nEnter 1, 2, or 3:');
  
  if (!action) return;
  
  if (action === '1') {
    // Add device to code
    const code = prompt('Enter the activation code to assign:').toUpperCase();
    if (!code) return;
    if (!/^[A-Z0-9]{4}-[A-Z0-9]{4}$/.test(code)) {
      showToast('Invalid code format', 'error');
      return;
    }
    
    try {
      const result = await apiRequest('/api/device/' + deviceId + '/assign-code', 'POST', { code });
      if (result.success) {
        showToast('✅ Device assigned to code: ' + code, 'success');
        location.reload();
      } else {
        showToast('❌ Failed: ' + (result.error || 'Unknown error'), 'error');
      }
    } catch (e) {
      showToast('❌ Error: ' + e.message, 'error');
    }
  } else if (action === '2') {
    // Remove device
    removeUser(deviceId);
  } else if (action === '3') {
    // Reactivate device
    reactivateDevice(deviceId);
  }
}

// ============================================
// APPROVE DEVICE REQUEST
// ============================================
async function approveDeviceRequest(requestId, deviceId) {
  if (!confirm('✅ Approve this device request?\n\nDevice will be added to the system.')) return;
  
  try {
    // First approve the request
    const result = await apiRequest('/api/request/' + requestId + '/respond', 'POST', { 
      status: 'approved',
      response: 'Device request approved'
    });
    
    if (result.success) {
      showToast('✅ Device request approved!', 'success');
      location.reload();
    } else {
      showToast('❌ Failed: ' + (result.error || 'Unknown error'), 'error');
    }
  } catch (e) {
    showToast('❌ Error: ' + e.message, 'error');
  }
}

// ============================================
// GENERATE CODE FOR USER (from code request)
// ============================================
async function generateCodeForUser(requestId, deviceId) {
  const username = prompt('Enter username for this code:', 'user_' + (deviceId ? deviceId.substring(0,8) : ''));
  if (username === null) return;
  if (!username || username.trim() === '') {
    showToast('Username is required', 'error');
    return;
  }
  
  const maxDevices = parseInt(prompt('Max devices for this code:', '10')) || 10;
  
  if (!confirm(`Generate code for "${username}" with ${maxDevices} device limit?`)) return;
  
  try {
    const result = await apiRequest('/api/generate-code', 'POST', { 
      username: username.trim(),
      maxDevices: maxDevices
    });
    
    if (result.success) {
      showToast('✅ Code generated: ' + result.code + ' for ' + result.username, 'success');
      location.reload();
    } else {
      showToast('❌ Failed: ' + (result.error || 'Unknown error'), 'error');
    }
  } catch (e) {
    showToast('❌ Error: ' + e.message, 'error');
  }
}

// ============================================
// REJECT REQUEST
// ============================================
async function rejectRequest(requestId) {
  if (!confirm('Reject this request?')) return;
  try {
    const result = await apiRequest('/api/request/' + requestId + '/respond', 'POST', { 
      status: 'rejected',
      response: 'Request rejected by admin'
    });
    if (result.success) {
      showToast('✅ Request rejected', 'success');
      location.reload();
    } else {
      showToast('❌ Failed: ' + (result.error || 'Unknown error'), 'error');
    }
  } catch (e) {
    showToast('❌ Error: ' + e.message, 'error');
  }
}
</script>
